# =============================================================================
# MCP System — Environment Configuration Reference
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- Core Application ---
MCP_ENV=development           # development | production | test
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_WORKERS=4                 # Uvicorn worker count (production)
MCP_SECRET_KEY=changeme-use-a-real-secret-in-production
MCP_DEBUG=false

# --- Redis (short-term memory + session cache) ---
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5
REDIS_TTL_SECONDS=3600        # Default TTL for short-term context

# --- Qdrant (long-term vector memory) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=               # Leave empty for local, set for Qdrant Cloud
QDRANT_COLLECTION=mcp_memory
QDRANT_VECTOR_SIZE=1536       # Match your embedding model dimension

# --- Embedding Model ---
EMBEDDING_PROVIDER=openai     # openai | sentence-transformers | cohere
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=64

# --- LLM (optional, for LLM-backed modules) ---
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...

# --- Auth ---
JWT_SECRET_KEY=changeme-jwt-secret-must-be-32-chars-min
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
API_KEY_HEADER=X-API-Key      # Header name for API key auth

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100       # Requests per window
RATE_LIMIT_WINDOW=60          # Window in seconds

# --- Observability ---
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json               # json | text
LOG_FILE=                     # Leave empty to log to stdout only
ENABLE_METRICS=true
METRICS_PORT=9091             # Prometheus metrics port
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=mcp-system

# --- Module System ---
MODULES_DIR=./src/modules/plugins  # Directory scanned for plugin discovery
MODULES_HOT_RELOAD=false           # Enable hot module reloading (dev only)
MODULES_TIMEOUT_SECONDS=30         # Max execution time per module call

# --- Context Management ---
CONTEXT_MAX_TOKENS=128000     # Max tokens per context window
CONTEXT_MAX_MESSAGES=1000     # Max messages per context
CONTEXT_TTL_SECONDS=86400     # How long inactive contexts live (24h)

# --- Storage ---
STORAGE_BACKEND=redis         # redis | memory (for testing only)
STORAGE_ENCRYPTION_KEY=       # Fernet key for encrypting stored contexts

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# --- Database (for persistent metadata, optional) ---
DATABASE_URL=postgresql+asyncpg://mcp:mcp@localhost:5432/mcp
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
